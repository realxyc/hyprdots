// Modified from: https://github.com/fastfetch-cli/fastfetch/pull/1025#issuecomment-2177566138
// Modified by: The HyDE Project
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "$(find \"${XDG_CONFIG_HOME:-$HOME/.config}/fastfetch/logos/\" -name \"*.png\" | shuf -n 1)",
    "height": 16,
    "padding": {
      "top": 1
    }
  },
  "display": {
    "color": {
      "separator": "blue"
    },
    "separator": " | "
  },
  "modules": [
    "break",
    "break",
    {
      "type": "kernel",
      "key": "  GNU/Linux ",
      "keyColor": "magenta"
    },
    {
      "type": "custom",
      "format": ">-----------<+>------------------------------------------<",
      "outputColor": "separator"
    },
    {
      "type": "host",
      "key": "ï„‰  MRB      ",
      "keyColor": "cyan"
    },
    {
      "type": "memory",
      "key": "î؟…  RAM      ",
      "keyColor": "cyan"
    },
    {
      "type": "cpu",
      "key": "َ°چ›  CPU      ",
      "showPeCoreCount": true,
      "keyColor": "cyan"
    },
    {
      "type": "gpu",
      "key": "َ°چ›  GPU      ",
      "keyColor": "cyan"
      //      "text": "lspci | grep -i vga | awk -F': | \\\\[|\\\\]' '{print $2 \" [\" $3 \"]\"}'"
    },
    //    {
    //      "type": "disk",
    //      "key": "َ°‰‰  Disk     ",
    //      "keyColor": "cyan",
    //    },
    {
      "type": "custom",
      "format": ">-----------<+>------------------------------------------<",
      "outputColor": "separator"
    },
    {
      "type": "wmtheme",
      "key": "َ°‰¼  Theme    ",
      "keyColor": "green"
    },
    {
      "type": "shell",
      "key": "ï’‰  Shell    ",
      "keyColor": "green"
    },
    {
      "type": "wm",
      "key": "ï€“  Session  ",
      "keyColor": "green"
    },
    {
      "type": "terminal",
      "key": "î‍•  Terminal ",
      "keyColor": "green"
    },
    {
      "type": "de",
      "key": "ï’ˆ  Desktop  ",
      "keyColor": "green"
    },
    {
      "type": "packages",
      "key": "َ°ڈ–  Packages ",
      "keyColor": "green"
    },
    {
      "type": "gpu",
      "key": "َ°چ›  G-Driver ",
      "format": "{3}",
      "keyColor": "green"
    },
    {
      "type": "custom",
      "format": ">-----------<+>------------------------------------------<",
      "outputColor": "separator"
    },
    {
      "type": "disk",
      "key": "َ°…گ  OS Age   ",
      "keyColor": "blue",
      "folders": "/",
      "format": "{days} days"
    },
    {
      "type": "uptime",
      "key": "َ°…گ  Uptime   ",
      "keyColor": "blue"
    },
    {
      "type": "custom",
      "format": ">-----------<+>------------------------------------------<",
      "outputColor": "separator"
    },
    "break",
    "break"
  ]
}